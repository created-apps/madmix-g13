# Supabase — Dashboard → Settings → API Keys → "Publishable and secret API keys" tab
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=sb_publishable_your-publishable-key-here
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your-secret-key-here

# Anthropic API Key — console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# CORS — comma-separated list of allowed frontend origins
# Dev: http://localhost:5173
# Prod: https://your-frontend.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Decision engine thresholds (all have sensible defaults; override as needed)
# SKIP_RATE_THRESHOLD=0.30
# LOW_SALES_MRP_THRESHOLD=5000.0
# A2S_THRESHOLD=0.45
# A2S_CONSECUTIVE_DAYS=3
# DECISIONS_CACHE_TTL_HOURS=24
# MIN_SURVEY_SAMPLE=5
